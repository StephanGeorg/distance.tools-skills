#!/usr/bin/env bash
set -euo pipefail

SKILL_NAME="distance-route"
INSTALL_DIR="${HOME}/.agents/skills/${SKILL_NAME}"
REPO_RAW="https://raw.githubusercontent.com/StephanGeorg/distance.tools-skills/main"

echo "Installing ${SKILL_NAME}..."

# Create the target directory
mkdir -p "$INSTALL_DIR"

# Download the skill files
echo "  Downloading SKILL.md..."
curl -fsSL "${REPO_RAW}/skills/distance-route/SKILL.md" -o "${INSTALL_DIR}/SKILL.md"

echo "  Downloading script..."
curl -fsSL "${REPO_RAW}/skills/distance-route/scripts/distance-route.sh" -o "${INSTALL_DIR}/distance-route.sh"
chmod +x "${INSTALL_DIR}/distance-route.sh"

# Download references
echo "  Downloading references..."
mkdir -p "${INSTALL_DIR}/references"
curl -fsSL "${REPO_RAW}/skills/distance-route/references/api-guide.md" -o "${INSTALL_DIR}/references/api-guide.md"
curl -fsSL "${REPO_RAW}/skills/distance-route/references/getting-started.md" -o "${INSTALL_DIR}/references/getting-started.md"

# Download README
echo "  Downloading README..."
curl -fsSL "${REPO_RAW}/skills/distance-route/README.md" -o "${INSTALL_DIR}/README.md"

echo "✅ Successfully installed ${SKILL_NAME}"
echo ""
echo "Setting up automatic PATH integration..."

# Add to shell configuration automatically
SHELL_CONFIG="$HOME/.bashrc"
if [ -f "$HOME/.zshrc" ]; then
    SHELL_CONFIG="$HOME/.zshrc"
elif [ -f "$HOME/.bash_profile" ]; then
    SHELL_CONFIG="$HOME/.bash_profile"
fi

# Add PATH to shell config if not already present
if ! grep -q "\.agents/skills" "$SHELL_CONFIG"; then
    echo "" >> "$SHELL_CONFIG"
    echo "# Distance Tools Skills - Auto-configured PATH" >> "$SHELL_CONFIG"
    echo "export PATH=\"$HOME/.agents/skills:\$PATH\"" >> "$SHELL_CONFIG"
    echo "✅ PATH automatically configured in $SHELL_CONFIG"
else
    echo "✅ PATH already configured in $SHELL_CONFIG"
fi

echo ""
echo "Setup Complete:"
echo "  1. Get API token: https://developers.distance.tools"
echo "  2. Set token:   export XBIlling_Token=\"your-api-token-here\""
echo "  3. Restart terminal or run: source $SHELL_CONFIG"
echo "  4. Test:       distance-route.shift Paris Berlin car"
echo ""
echo "🎉 The installer has automatically configured your PATH!"
echo "After restarting your terminal, run: distance-route.sh Paris Berlin car"
